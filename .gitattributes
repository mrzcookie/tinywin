# Normalise line endings so the five parallel worktrees don't produce whitespace-only diffs.
* text=auto eol=lf

*.sln    text eol=crlf
*.slnx   text eol=lf
*.csproj text eol=lf
*.props  text eol=lf
*.ps1    text eol=crlf
*.cmd    text eol=crlf
*.bat    text eol=crlf

*.iso  binary
*.wim  binary
*.esd  binary
*.png  binary
*.ico  binary
