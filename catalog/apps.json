{
  "schemaVersion": 1,
  "components": [
    {
      "id": "apps.edge",
      "name": "Microsoft Edge",
      "category": "Microsoft Apps",
      "description": "Removes the Edge browser, EdgeUpdate and EdgeCore, along with their uninstall entries and updater services.",
      "risk": "Caution",
      "defaultIn": ["balanced", "aggressive", "core"],
      "estimatedSavingsMb": 820,
      "appliesTo": { "minBuild": 26100, "maxBuild": 26299 },
      "requires": [],
      "conflicts": [],
      "breaks": [
        "No browser is installed until you install one — plan to have an installer on hand",
        "Some Settings pages and Help links open nothing",
        "PDF files have no default handler"
      ],
      "actions": [
        { "type": "DeleteDirectory", "path": "Program Files (x86)\\Microsoft\\Edge", "optional": true },
        { "type": "DeleteDirectory", "path": "Program Files (x86)\\Microsoft\\EdgeUpdate", "optional": true },
        { "type": "DeleteDirectory", "path": "Program Files (x86)\\Microsoft\\EdgeCore", "optional": true },
        { "type": "DisableService", "name": "edgeupdate", "startType": 4, "optional": true },
        { "type": "DisableService", "name": "edgeupdatem", "startType": 4, "optional": true },
        { "type": "DisableService", "name": "MicrosoftEdgeElevationService", "startType": 4, "optional": true },
        {
          "type": "DeleteRegistryKey",
          "hive": "Software",
          "key": "WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Microsoft Edge",
          "optional": true
        },
        {
          "type": "DeleteRegistryKey",
          "hive": "Software",
          "key": "WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\Microsoft Edge Update",
          "optional": true
        },
        {
          "type": "SetRegistry",
          "hive": "Software",
          "key": "Policies\\Microsoft\\Edge",
          "valueName": "HubsSidebarEnabled",
          "kind": "Dword",
          "data": 0
        }
      ]
    },
    {
      "id": "apps.edge.webview2",
      "name": "WebView2 Runtime",
      "category": "Microsoft Apps",
      "description": "Removes the shared WebView2 runtime. Off by default in every preset, including Core — this is opt-in only.",
      "risk": "Breaking",
      "defaultIn": [],
      "estimatedSavingsMb": 620,
      "appliesTo": { "minBuild": 26100, "maxBuild": 26299 },
      "requires": ["apps.edge"],
      "conflicts": [],
      "breaks": [
        "Any third-party application embedding WebView2 fails to start, often with no useful error",
        "Microsoft Teams, many Office surfaces and numerous installers stop working",
        "Apps that bundle their own WebView2 installer will silently reinstall it"
      ],
      "actions": [
        { "type": "DeleteDirectory", "path": "Windows\\System32\\Microsoft-Edge-WebView", "optional": true },
        { "type": "DeleteDirectory", "path": "Program Files (x86)\\Microsoft\\EdgeWebView", "optional": true }
      ]
    },
    {
      "id": "apps.onedrive",
      "name": "OneDrive",
      "category": "Microsoft Apps",
      "description": "Removes the OneDrive setup stub and disables file sync by policy.",
      "risk": "Safe",
      "defaultIn": ["balanced", "aggressive", "core"],
      "estimatedSavingsMb": 86,
      "appliesTo": { "minBuild": 26100, "maxBuild": 26299 },
      "requires": [],
      "conflicts": [],
      "breaks": [
        "No OneDrive sync; Documents and Pictures stay local unless you install it yourself"
      ],
      "actions": [
        { "type": "DeleteFile", "path": "Windows\\System32\\OneDriveSetup.exe", "optional": true },
        {
          "type": "SetRegistry",
          "hive": "Software",
          "key": "Policies\\Microsoft\\Windows\\OneDrive",
          "valueName": "DisableFileSyncNGSC",
          "kind": "Dword",
          "data": 1
        }
      ]
    },
    {
      "id": "apps.teams",
      "name": "Microsoft Teams",
      "category": "Microsoft Apps",
      "description": "Removes the in-box Teams client. The package is a small stub that downloads the real client on first launch.",
