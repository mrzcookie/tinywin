        {
          "type": "SetRegistry",
          "hive": "NtUser",
          "key": "Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
          "valueName": "SubscribedContent-338389Enabled",
          "kind": "Dword",
          "data": 0
        },
        {
          "type": "SetRegistry",
          "hive": "NtUser",
          "key": "Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
          "valueName": "SubscribedContent-338393Enabled",
          "kind": "Dword",
          "data": 0
        }
