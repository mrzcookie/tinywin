<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TinyWin.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="TinyWin">

    <!-- Mica, and the system light/dark theme by default. -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="40" Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="14,0,0,0" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE9F5;" FontSize="14" />
                <TextBlock Text="TinyWin" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                <TextBlock x:Name="ElevationNote"
                           Text="running as administrator"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <muxc:NavigationView x:Name="Nav"
                             Grid.Row="1"
                             IsBackButtonVisible="Collapsed"
                             IsSettingsVisible="False"
                             PaneDisplayMode="Left"
                             OpenPaneLength="240"
                             IsPaneToggleButtonVisible="True"
                             SelectionChanged="OnNavigationSelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Home" Tag="home">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Source" Tag="source">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE958;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Customize" Tag="customize">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71D;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Tweaks" Tag="tweaks">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Review" Tag="review">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C3;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <!--
                Build and Done are pinned to the bottom, and Build stays disabled until the Review
                page's gate is satisfied. Nothing destructive is reachable from the launch screen.
            -->
            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem x:Name="BuildNavItem" Content="Build" Tag="build" IsEnabled="False">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem x:Name="DoneNavItem" Content="Done" Tag="done" IsEnabled="False">
                    <muxc:NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73E;" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
