<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TinyWin.App.Views.CustomizePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:ctl="using:TinyWin.App.Controls"
    xmlns:local="using:TinyWin.App.Views"
    xmlns:vm="using:TinyWin.App.ViewModels">

    <Page.Resources>

        <!-- Category row: tri-state checkbox over the visible children. -->
        <DataTemplate x:Key="CategoryTemplate" x:DataType="vm:CategoryNode">
            <TreeViewItem ItemsSource="{x:Bind Children}"
                          IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                          Padding="0,2">
                <Grid ColumnSpacing="12" Padding="0,6" MinWidth="640">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              MinWidth="0"
                              IsThreeState="True"
                              IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                              AutomationProperties.Name="{x:Bind Name}" />

                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Name}"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind SavingsText, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />

                    <TextBlock Grid.Column="3"
                               Text="{x:Bind SummaryText, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               MinWidth="110"
                               TextAlignment="Right" />
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <!-- Component row: checkbox, name and description, risk badge, size, and what it breaks. -->
        <DataTemplate x:Key="ComponentTemplate" x:DataType="vm:ComponentNode">
            <TreeViewItem Padding="0,2">
                <Grid ColumnSpacing="12" Padding="0,6" MinWidth="620">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              MinWidth="0"
                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                              AutomationProperties.Name="{x:Bind Name}" />

                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyTextBlockStyle}" />
                        <TextBlock Text="{x:Bind Description}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind RequiresText}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   Visibility="{x:Bind HasRequires, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                    <ctl:RiskBadge Grid.Column="2" Risk="{x:Bind Risk}" />

                    <TextBlock Grid.Column="3"
                               Text="{x:Bind SavingsText}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"
                               MinWidth="64"
                               TextAlignment="Right" />

                    <!-- Hover gives the tooltip; the button gives the same thing to keyboard and
                         touch, which a hover-only affordance would lock out. -->
                    <Button Grid.Column="4"
                            Padding="6,2"
                            Background="Transparent"
                            BorderThickness="0"
                            Visibility="{x:Bind HasBreaks, Converter={StaticResource BoolToVisibility}}"
                            AutomationProperties.Name="What this breaks">
                        <FontIcon Glyph="&#xE946;" FontSize="14" />
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="10" MaxWidth="420">
                                    <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <ctl:RiskBadge Risk="{x:Bind Risk}" HorizontalAlignment="Left" />
                                    <TextBlock Text="What this breaks" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <ItemsControl ItemsSource="{x:Bind Breaks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <TextBlock Text="{x:Bind}" TextWrapping="Wrap" Margin="0,0,0,6" Style="{StaticResource BodyTextBlockStyle}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{x:Bind Id}" /><Run Text="  ·  " /><Run Text="{x:Bind ActionCountText}" /><Run Text="  ·  " /><Run Text="{x:Bind AppliesToText}" />
                                    </TextBlock>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <ToolTipService.ToolTip>
                        <ToolTip>
                            <StackPanel Spacing="6" MaxWidth="380">
                                <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind AppliesToText}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />
                            </StackPanel>
                        </ToolTip>
                    </ToolTipService.ToolTip>
                </Grid>
            </TreeViewItem>
        </DataTemplate>

        <local:NodeTemplateSelector x:Key="NodeSelector"
                                    Category="{StaticResource CategoryTemplate}"
                                    Component="{StaticResource ComponentTemplate}" />
    </Page.Resources>

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title on the left, the live estimate on the right. -->
        <Grid Grid.Row="0" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Customize" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{x:Bind ViewModel.SelectedCountText, Mode=OneWay}" />
                    <Run Text="  ·  highest risk " />
                    <Run Text="{x:Bind ViewModel.HighestRiskLabel, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,12"
                    MinWidth="300">
                <StackPanel Spacing="2">
                    <TextBlock Text="Estimated ISO size" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind ViewModel.SizeBeforeText, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <FontIcon Glyph="&#xE72A;" FontSize="14" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.SizeAfterText, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="about " /><Run Text="{x:Bind ViewModel.SavingsText, Mode=OneWay}" /><Run Text=" off the ISO · " />
                        <Run Text="{x:Bind ViewModel.PayloadText, Mode=OneWay}" /><Run Text=" of files removed" />
                    </TextBlock>
                    <TextBlock Text="Pick an ISO on the Source page to see sizes."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Visibility="{x:Bind ViewModel.HasSizeEstimate, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Preset, search, import/export. -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      MinWidth="220"
                      Header="Preset"
                      ItemsSource="{x:Bind ViewModel.Presets}"
                      SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                      DisplayMemberPath="Name" />

            <TextBox Grid.Column="1"
                     Header="Search"
                     PlaceholderText="Filter by name, id, description or consequence"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <Button Content="Import" Command="{x:Bind ViewModel.ImportPresetCommand}" />
                <Button Content="Export" Command="{x:Bind ViewModel.ExportPresetCommand}" />
                <Button Content="Clear" Command="{x:Bind ViewModel.ClearSelectionCommand}" />
            </StackPanel>
        </Grid>

        <muxc:InfoBar Grid.Row="2"
                      IsOpen="{x:Bind ViewModel.HasStatus, Mode=OneWay}"
                      IsClosable="False"
                      Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />

        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <TreeView ItemsSource="{x:Bind ViewModel.Categories}"
                      ItemTemplateSelector="{StaticResource NodeSelector}"
                      SelectionMode="None"
                      CanDragItems="False"
                      CanReorderItems="False"
                      Padding="8" />
        </Border>
    </Grid>
</Page>
