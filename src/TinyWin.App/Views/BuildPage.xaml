<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TinyWin.App.Views.BuildPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:TinyWin.App.ViewModels">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Build" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="Start build"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.CanStart, Mode=OneWay}"
                        Command="{x:Bind ViewModel.StartCommand}" />
                <Button Content="Cancel"
                        IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay}"
                        Command="{x:Bind ViewModel.CancelCommand}" />
            </StackPanel>
        </Grid>

        <!-- Progress: ring, percentage, elapsed and ETA. -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="72" Height="72">
                    <muxc:ProgressRing IsIndeterminate="False"
                                       Value="{x:Bind ViewModel.OverallPercent, Mode=OneWay}"
                                       Maximum="100"
                                       Width="72"
                                       Height="72" />
                    <TextBlock Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </Grid>

                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                    <muxc:ProgressBar Value="{x:Bind ViewModel.OverallPercent, Mode=OneWay}" Maximum="100" />
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="elapsed " /><Run Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Text="{x:Bind ViewModel.EtaText, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="Cancelling dismounts the image with /discard. It never leaves an image mounted."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Stage list. -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ScrollViewer Padding="8">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Stages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:StageRow">
                                <Grid ColumnSpacing="12" Padding="10,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <FontIcon Glyph="{x:Bind Glyph, Mode=OneWay}"
                                                  FontSize="15"
                                                  Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                                        <muxc:ProgressRing IsActive="True"
                                                           Width="15"
                                                           Height="15"
                                                           Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>

                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind Detail, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{x:Bind Detail, Mode=OneWay, Converter={StaticResource StringToVisibility}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Live log. -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Log" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="AutoScrollToggle" Grid.Column="1" Content="Follow" IsChecked="True" />
                        <Button Grid.Column="2" Content="Copy log" Command="{x:Bind ViewModel.CopyLogCommand}" />
                    </Grid>

                    <ListView x:Name="LogList"
                              Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.Log}"
                              SelectionMode="None"
                              Padding="8,0,8,12">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="Padding" Value="8,1" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
