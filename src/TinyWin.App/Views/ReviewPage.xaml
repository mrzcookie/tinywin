<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TinyWin.App.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:TinyWin.App.ViewModels">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16" MaxWidth="{StaticResource PageMaxWidth}" HorizontalAlignment="Left">

            <StackPanel Spacing="4">
                <TextBlock Text="Review" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Everything that will run, grouped by the stage that runs it. Read-only."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.SummaryText, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="Source&#x09;" /><Run Text="{x:Bind ViewModel.SourceText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="Edition&#x09;" /><Run Text="{x:Bind ViewModel.EditionText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="Output&#x09;" /><Run Text="{x:Bind ViewModel.OutputText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Warnings escalate one tier at a time; only one of these is ever open. -->
            <muxc:InfoBar IsOpen="{x:Bind ViewModel.ShowCautionNotice, Mode=OneWay}"
                          IsClosable="False"
                          Severity="Informational"
                          Title="Some of this removes features"
                          Message="Your selection loses features that some people rely on, but leaves the operating system serviceable. Windows Update, Defender and the component store are untouched." />

            <muxc:InfoBar IsOpen="{x:Bind ViewModel.ShowBreakingNotice, Mode=OneWay}"
                          IsClosable="False"
                          Severity="Warning"
                          Title="This selection is known to break unrelated software"
                          Message="At least one component in this build is in the breaking tier. Read the per-component consequences on the Customize page before continuing." />

            <muxc:InfoBar IsOpen="{x:Bind ViewModel.HasWarnings, Mode=OneWay}"
                          IsClosable="False"
                          Severity="Warning"
                          Title="Not validated against this media">
                <muxc:InfoBar.Content>
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ResolverWarnings}" Margin="0,8,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </muxc:InfoBar.Content>
            </muxc:InfoBar>

            <!-- The unserviceable gate. A typed string, not a click. -->
            <muxc:InfoBar IsOpen="{x:Bind ViewModel.RequiresConfirmation, Mode=OneWay}"
                          IsClosable="False"
                          Severity="Error"
                          Title="This build cannot be serviced afterwards">
                <muxc:InfoBar.Content>
                    <StackPanel Spacing="12" Margin="0,10,0,14">
                        <TextBlock Text="{x:Bind ViewModel.ConfirmationPrompt, Mode=OneWay}" TextWrapping="Wrap" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}">
                            <Run Text="No antivirus, no SmartScreen, no tamper protection. Windows Update, in-place repair and adding features back are all unavailable on the resulting image. Intended for disposable test and lab VMs." />
                        </TextBlock>
                        <TextBox MaxWidth="320"
                                 HorizontalAlignment="Left"
                                 PlaceholderText="UNSERVICEABLE"
                                 AutomationProperties.Name="Type UNSERVICEABLE to confirm"
                                 Text="{x:Bind ViewModel.ConfirmationText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </muxc:InfoBar.Content>
            </muxc:InfoBar>

            <TextBlock Text="Actions" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReviewGroup">
                        <muxc:Expander HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Stretch"
                                       Margin="0,0,0,8">
                            <muxc:Expander.Header>
                                <Grid ColumnSpacing="16" Padding="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind Subtitle}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind CountText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </muxc:Expander.Header>

                            <ItemsControl ItemsSource="{x:Bind Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ReviewItem">
                                        <Grid ColumnSpacing="16" Padding="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Text}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind ComponentName}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </muxc:Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,8,0,0">
                <StackPanel Spacing="10">
                    <Button Content="Unlock and go to Build"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.CanBuild, Mode=OneWay}"
                            Click="OnGoToBuild" />
                    <TextBlock Text="{x:Bind ViewModel.BlockedReason, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.BlockedReason, Mode=OneWay, Converter={StaticResource StringToVisibility}}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
